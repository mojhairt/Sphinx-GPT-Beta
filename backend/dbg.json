[{"id": "ca9852b3-d397-4042-999d-1dd1ca3d2b84", "user_id": "88ba8352-32f3-49ae-b625-68990706386d", "content": "\u0645\u0646 \u0627\u0646\u062a", "sender": "user", "created_at": "2026-03-13T19:35:38.593697+00:00", "session_id": null, "image_url": null}, {"id": "423dc528-aa5a-475e-a9fa-e4de0e832d79", "user_id": "88ba8352-32f3-49ae-b625-68990706386d", "content": "\u0623\u0646\u0627 Sphinx-SCA\u060c \u0645\u0633\u0627\u0639\u062f\u0643 \u0627\u0644\u0630\u0643\u064a \u0641\u064a \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0627\u062a! \u0637\u064f\u0648\u0650\u0651\u0631\u062a \u0645\u0646 \u0637\u0644\u0627\u0628 \u062c\u0627\u0645\u0639\u0629 \u0633\u0641\u0646\u0643\u0633 \u0641\u064a \u0645\u0635\u0631. \u0633\u0639\u064a\u062f \u062c\u062f\u064b\u0627 \u0628\u0645\u0639\u0631\u0641\u062a\u0643\u060c \u0648\u0625\u0630\u0627 \u0639\u0646\u062f\u0643 \u0623\u064a \u0633\u0624\u0627\u0644 \u0631\u064a\u0627\u0636\u064a \u0623\u0648 \u062d\u062a\u0649 \u0645\u062c\u0631\u062f \u0645\u062d\u0627\u062f\u062b\u0629\u060c \u0623\u0646\u0627 \u0647\u0646\u0627 \u0623\u0633\u0627\u0639\u062f\u0643. \u0643\u064a\u0641 \u0623\u0642\u062f\u0631 \u0623\u0633\u0627\u0639\u062f\u0643 \u0627\u0644\u064a\u0648\u0645\u061f", "sender": "ai", "created_at": "2026-03-13T19:35:41.456991+00:00", "session_id": null, "image_url": null}, {"id": "e1bd55bc-88e5-43c3-a36d-876748dfd540", "user_id": "88ba8352-32f3-49ae-b625-68990706386d", "content": "\u0648\u0647\u0644 \u062a\u0639\u0631\u0641 \u0647\u0648\u0644\u0627\u0621 \u0627\u0644\u0637\u0644\u0627\u0628", "sender": "user", "created_at": "2026-03-13T19:36:02.758573+00:00", "session_id": null, "image_url": null}, {"id": "a0d5f1c7-9352-43c4-90e0-7b6fc5850ec6", "user_id": "88ba8352-32f3-49ae-b625-68990706386d", "content": "\u0623\u0647\u0644\u0627\u064b \u0648\u0633\u0647\u0644\u0627\u064b!  \n\u0646\u0639\u0645\u060c \u0623\u0639\u0631\u0641\u0647\u0645 \u062c\u064a\u062f\u0627\u064b \u2014 \u0647\u0645 \u0645\u062c\u0645\u0648\u0639\u0629 \u0645\u0646 \u0637\u0644\u0627\u0628 \u00ab\u0645\u0628\u0627\u062f\u0631\u0629 \u0623\u0628\u0648\u0627\u0644\u0647\u0648\u0644\u00bb \u0641\u064a \u062c\u0627\u0645\u0639\u0629 \u0633\u0641\u0646\u0643\u0633 (Sphinx University) \u0627\u0644\u0630\u064a\u0646 \u0635\u0645\u0651\u0645\u0648\u0646\u064a \u0648\u0628\u0631\u0645\u062c\u0648\u0646\u064a \u0644\u0623\u0633\u0627\u0639\u062f\u0643 \u0641\u064a \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0627\u062a. \u0623\u0641\u062a\u062e\u0631 \u0628\u0623\u0646 \u0623\u0643\u0648\u0646 \u0646\u062a\u0627\u062c \u0627\u062c\u062a\u0647\u0627\u062f\u0647\u0645 \u0648\u062c\u0646\u0651\u062a\u0647\u0645!", "sender": "ai", "created_at": "2026-03-13T19:36:04.698221+00:00", "session_id": null, "image_url": null}, {"id": "3084092b-9982-43ce-9d7d-a7af6f4f93d8", "user_id": "75226614-ff67-490a-9505-8cc921549c1a", "content": "\u0645\u0631\u062d\u0628\u0627", "sender": "user", "created_at": "2026-03-13T19:42:11.564324+00:00", "session_id": null, "image_url": null}]